# =============================================================================
# Edupo TMS — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values:
#   cp .env.example .env
#
# Required vars are marked [REQUIRED]. Optional vars have defaults noted.

# =============================================================================
# APPLICATION
# =============================================================================

# [REQUIRED] Environment mode: local | staging | production
ENVIRONMENT=local

# [REQUIRED] Domain for the application (used in emails, links, etc.)
DOMAIN=localhost

# Frontend URL (used for CORS and email links)
FRONTEND_HOST=http://localhost:3000

# Comma-separated list of allowed CORS origins
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# =============================================================================
# AUTHENTICATION
# =============================================================================

# [REQUIRED] JWT signing key — CHANGE THIS for any non-local deployment
# Generate one with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=changethis

# Token expiry in minutes (default: 8 days)
# ACCESS_TOKEN_EXPIRE_MINUTES=11520

# =============================================================================
# DATABASE (PostgreSQL)
# =============================================================================

# [REQUIRED] PostgreSQL connection
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_USER=edupo
POSTGRES_PASSWORD=changethis
POSTGRES_DB=edupo

# =============================================================================
# SUPERUSER (seeded on first run)
# =============================================================================

# [REQUIRED] Initial admin account credentials
FIRST_SUPERUSER=admin@example.com
FIRST_SUPERUSER_PASSWORD=changethis

# =============================================================================
# FILE STORAGE (Cloudflare R2 / S3-compatible) — Optional
# =============================================================================

# Uncomment and configure to enable cloud file storage
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=
# R2_ENDPOINT=
# R2_REGION=auto
# S3_ENDPOINT=

# =============================================================================
# EMAIL (SMTP) — Optional
# =============================================================================

# Uncomment and configure to enable email sending (account notifications, etc.)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_TLS=true
# EMAILS_FROM_EMAIL=
# EMAILS_FROM_NAME=Edupo TMS
# EMAIL_RESET_TOKEN_EXPIRE_HOURS=48

# =============================================================================
# MONITORING — Optional
# =============================================================================

# Sentry DSN for error tracking
# SENTRY_DSN=

# =============================================================================
# GEOLOCATION — Optional
# =============================================================================

# Radar.io API key for location autocomplete
# RADAR_API_KEY=
